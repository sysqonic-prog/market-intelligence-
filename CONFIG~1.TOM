[theme]
base            = "dark"
primaryColor    = "#1565c0"
backgroundColor = "#0a0e1a"
secondaryBackgroundColor = "#111827"
textColor       = "#e8eaf6"
font            = "sans serif"

[server]
headless        = true
enableCORS      = false
enableXsrfProtection = true

[browser]
gatherUsageStats = false
